#!/usr/bin/env bash
set -euo pipefail

source .config/ui.sh

START_TIME=$(date +%s)

branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

# Block commits to main
if [[ "${branch}" == "main" ]]; then
  print_error "direct commits to main not allowed"
  exit 1
fi

# Validate branch naming
PATTERN="^(feat|fix|chore|docs|refactor|test|ci|style|perf|build)/[a-z0-9]+(-[a-z0-9]+)*$"
if [[ -n "${branch}" ]] && ! [[ "${branch}" =~ ${PATTERN} ]]; then
  print_error "branch '${branch}' invalid"
  echo "Expected: type/description (e.g. feat/google-auth)"
  exit 1
fi

# === FORMATTING ===
print_section "Formatting"

STEP_START=$(date +%s)
pnpm lint --write > /dev/null 2>&1
BIOME_EXIT=$?
STEP_END=$(date +%s)
if [[ $BIOME_EXIT -eq 0 ]]; then
  print_step "01/15" "biome" "success" "$((STEP_END - STEP_START))s"
else
  print_step "01/15" "biome" "error"
  pnpm lint --write
  exit 1
fi

STEP_START=$(date +%s)
OUTPUT=$(pnpm exec tsc -p .config/tsconfig.json --noEmit 2>&1)
TS_EXIT=$?
STEP_END=$(date +%s)
if [[ $TS_EXIT -eq 0 ]]; then
  print_step "02/15" "typescript" "success" "$((STEP_END - STEP_START))s"
else
  print_step "02/15" "typescript" "error"
  echo "$OUTPUT"
  exit 1
fi

# === QUALITY ===
print_section "Quality"

STEP_START=$(date +%s)
bash .config/check-filesize.sh 2>&1
FILESIZE_EXIT=$?
STEP_END=$(date +%s)
if [[ $FILESIZE_EXIT -eq 0 ]]; then
  print_step "03/15" "filesize" "success" "$((STEP_END - STEP_START))s"
else
  print_step "03/15" "filesize" "error"
  bash .config/check-filesize.sh
  exit 1
fi

STEP_START=$(date +%s)
bash .config/check-complexity.sh 2>&1
COMPLEXITY_EXIT=$?
STEP_END=$(date +%s)
if [[ $COMPLEXITY_EXIT -eq 0 ]]; then
  print_step "04/15" "complexity" "success" "$((STEP_END - STEP_START))s"
else
  print_step "04/15" "complexity" "error"
  bash .config/check-complexity.sh
  exit 1
fi

STEP_START=$(date +%s)
bash .config/check-comments.sh 2>&1
COMMENTS_EXIT=$?
STEP_END=$(date +%s)
if [[ $COMMENTS_EXIT -eq 0 ]]; then
  print_step "05/15" "comments" "success" "$((STEP_END - STEP_START))s"
else
  print_step "05/15" "comments" "error"
  bash .config/check-comments.sh
  exit 1
fi

# === ARCHITECTURE ===
print_section "Architecture"

STEP_START=$(date +%s)
bash .config/check-colors.sh 2>&1
COLORS_EXIT=$?
STEP_END=$(date +%s)
if [[ $COLORS_EXIT -eq 0 ]]; then
  print_step "06/15" "colors" "success" "$((STEP_END - STEP_START))s"
else
  print_step "06/15" "colors" "error"
  bash .config/check-colors.sh
  exit 1
fi

STEP_START=$(date +%s)
bash .config/check-search.sh 2>&1
SEARCH_EXIT=$?
STEP_END=$(date +%s)
if [[ $SEARCH_EXIT -eq 0 ]]; then
  print_step "07/15" "search" "success" "$((STEP_END - STEP_START))s"
else
  print_step "07/15" "search" "error"
  bash .config/check-search.sh
  exit 1
fi

STEP_START=$(date +%s)
bash .config/check-echo.sh > /dev/null 2>&1
ECHO_EXIT=$?
STEP_END=$(date +%s)
if [[ $ECHO_EXIT -eq 0 ]]; then
  print_step "08/15" "echo" "success" "$((STEP_END - STEP_START))s"
else
  print_step "08/15" "echo" "error"
  bash .config/check-echo.sh
  exit 1
fi

# === SECURITY ===
print_section "Security"

if command -v gitleaks > /dev/null 2>&1; then
  STEP_START=$(date +%s)
  gitleaks detect --no-git --redact > /dev/null 2>&1
  GITLEAKS_EXIT=$?
  STEP_END=$(date +%s)
  if [[ $GITLEAKS_EXIT -eq 0 ]]; then
    print_step "09/15" "gitleaks" "success" "$((STEP_END - STEP_START))s"
  else
    print_step "09/15" "gitleaks" "error"
    gitleaks detect --no-git --redact
    exit 1
  fi
else
  print_step "09/15" "gitleaks" "skip" "not installed"
fi

STEP_START=$(date +%s)
bash .config/check-pii.sh > /dev/null 2>&1
PII_EXIT=$?
STEP_END=$(date +%s)
if [[ $PII_EXIT -eq 0 ]]; then
  print_step "10/15" "pii" "success" "$((STEP_END - STEP_START))s"
else
  print_step "10/15" "pii" "error"
  bash .config/check-pii.sh
  exit 1
fi

# === STYLE ===
print_section "Style"

STEP_START=$(date +%s)
bash .config/check-language.sh > /dev/null 2>&1
LANGUAGE_EXIT=$?
STEP_END=$(date +%s)
if [[ $LANGUAGE_EXIT -eq 0 ]]; then
  print_step "11/15" "language" "success" "$((STEP_END - STEP_START))s"
else
  print_step "11/15" "language" "error"
  bash .config/check-language.sh
  exit 1
fi

STEP_START=$(date +%s)
EMOJI_FILES=$(bash .config/search.sh '[\x{1F300}-\x{1F9FF}]' 2>/dev/null | cut -d: -f1 | sort -u | grep -v "pre-commit" || true)
if [[ -n "$EMOJI_FILES" ]]; then
  for file in $EMOJI_FILES; do
    sed -i '' 's/[\x{1F300}-\x{1F9FF}]//g' "$file" 2>/dev/null || \
    sed -i 's/[\x{1F300}-\x{1F9FF}]//g' "$file" 2>/dev/null || true
  done
  git add $EMOJI_FILES
  STEP_END=$(date +%s)
  print_step "12/15" "emoji" "fixed" "removed, $((STEP_END - STEP_START))s"
else
  STEP_END=$(date +%s)
  print_step "12/15" "emoji" "success" "$((STEP_END - STEP_START))s"
fi

END_TIME=$(date +%s)
print_summary "$((END_TIME - START_TIME))s"
